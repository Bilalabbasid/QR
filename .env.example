# ============================================================
# ReviewIQ — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-only — never expose to client

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000           # e.g. https://yourapp.com in prod
NEXT_PUBLIC_SITE_URL=http://localhost:3000          # Used by Edge Functions for revalidation

# ── Google OAuth ─────────────────────────────────────────────
# Credentials from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret     # Server-only
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                               # Server-only

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                       # Server-only
STRIPE_WEBHOOK_SECRET=whsec_...                     # Server-only — from Stripe Dashboard

# ── Cache Revalidation ───────────────────────────────────────
# Random secret used by the Edge Function to call /api/revalidate
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=your-random-secret-min-16-chars
